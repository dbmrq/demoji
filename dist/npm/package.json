{
  "name": "demoji",
  "version": "0.1.0",
  "description": "A fast CLI tool to remove or replace emoji characters from source code files",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dbmrq/demoji.git"
  },
  "homepage": "https://github.com/dbmrq/demoji",
  "bugs": {
